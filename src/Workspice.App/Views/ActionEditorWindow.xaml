<Window x:Class="Workspice.App.Views.ActionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アクション編集"
        Width="840"
        Height="860"
        MinWidth="760"
        MinHeight="760"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Style="{StaticResource HeroCardStyle}"
            Margin="0,0,0,18">
      <StackPanel>
        <TextBlock Text="Action Designer"
                   Style="{StaticResource WindowTitleTextStyle}" />
        <TextBlock Text="起動、コマンド、サービス制御の各アクションを定義し、必要なら事前チェックと事後確認を追加します。"
                   Style="{StaticResource HeroSubtitleTextStyle}"
                   Margin="0,10,0,0" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,18">
          <StackPanel>
            <TextBlock Text="基本設定"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="アクションの識別名、種別、タイムアウト、確認フラグをここで設定します。"
                       Style="{StaticResource SectionSubtitleTextStyle}"
                       Margin="0,6,0,0" />

            <Grid Margin="0,20,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="種別"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <ComboBox Grid.Row="0"
                        Grid.Column="1"
                        x:Name="ActionTypeComboBox"
                        SelectionChanged="ActionTypeComboBox_SelectionChanged" />

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Text="名前"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <TextBox Grid.Row="1"
                       Grid.Column="1"
                       x:Name="ActionNameTextBox"
                       Margin="0,14,0,0" />

              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Text="タイムアウト(秒)"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <TextBox Grid.Row="2"
                       Grid.Column="1"
                       x:Name="TimeoutTextBox"
                       Margin="0,14,0,0" />

              <StackPanel Grid.Row="3"
                          Grid.Column="1"
                          Orientation="Horizontal"
                          Margin="0,16,0,0">
                <CheckBox x:Name="PromptBeforeRunCheckBox"
                          Content="実行前に確認する"
                          Margin="0,0,18,0" />
                <CheckBox x:Name="EnabledCheckBox"
                          Content="有効"
                          IsChecked="True" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <GroupBox Header="アクション詳細"
                  Margin="0,0,0,18">
          <Grid>
            <StackPanel x:Name="ApplicationLaunchPanel">
              <TextBlock Text="実行ファイル"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="ExecutablePathTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="引数"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="ApplicationArgumentsTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="作業ディレクトリ"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="ApplicationWorkingDirectoryTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="RunLevel"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <ComboBox x:Name="ApplicationRunLevelComboBox"
                        Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel x:Name="CommandExecutionPanel"
                        Visibility="Collapsed">
              <TextBlock Text="ファイル名"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="CommandFileNameTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="引数"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="CommandArgumentsTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="作業ディレクトリ"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="CommandWorkingDirectoryTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="RunLevel"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <ComboBox x:Name="CommandRunLevelComboBox"
                        Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel x:Name="ServiceControlPanel"
                        Visibility="Collapsed">
              <TextBlock Text="サービス名"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="ServiceNameTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="操作"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <ComboBox x:Name="ServiceOperationComboBox"
                        Margin="0,6,0,0" />
            </StackPanel>
          </Grid>
        </GroupBox>

        <GroupBox Header="事前条件チェック"
                  Margin="0,0,0,18">
          <DockPanel Margin="0">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        Margin="0,16,0,0">
              <Button Content="追加"
                      Width="82"
                      Margin="0,0,10,0"
                      Tag="Primary"
                      Click="AddPrecondition_Click" />
              <Button Content="編集"
                      Width="82"
                      Margin="0,0,10,0"
                      Click="EditPrecondition_Click" />
              <Button Content="削除"
                      Width="82"
                      Tag="Danger"
                      Click="RemovePrecondition_Click" />
            </StackPanel>
            <ListBox x:Name="PreconditionsListBox"
                     DisplayMemberPath="Command" />
          </DockPanel>
        </GroupBox>

        <GroupBox Header="事後確認">
          <StackPanel>
            <CheckBox x:Name="EnablePostCheckCheckBox"
                      Content="事後確認を有効化"
                      Checked="EnablePostCheckChanged"
                      Unchecked="EnablePostCheckChanged" />

            <Grid Margin="0,16,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="モード"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <ComboBox Grid.Row="0"
                        Grid.Column="1"
                        x:Name="PostCheckModeComboBox"
                        SelectionChanged="PostCheckModeComboBox_SelectionChanged" />

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Text="タイムアウト(秒)"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <TextBox Grid.Row="1"
                       Grid.Column="1"
                       x:Name="PostCheckTimeoutTextBox"
                       Margin="0,14,0,0" />

              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Text="ポーリング間隔(ms)"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <TextBox Grid.Row="2"
                       Grid.Column="1"
                       x:Name="PostCheckPollTextBox"
                       Margin="0,14,0,0" />
            </Grid>

            <StackPanel x:Name="ProcessExistsPanel"
                        Margin="0,16,0,0">
              <TextBlock Text="プロセス名"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="PostCheckProcessNameTextBox"
                       Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel x:Name="CommandCheckPanel"
                        Margin="0,16,0,0"
                        Visibility="Collapsed">
              <Button Content="CommandCheck を編集"
                      Width="190"
                      HorizontalAlignment="Left"
                      Click="EditPostCheckCommand_Click" />
              <TextBlock x:Name="PostCheckCommandSummaryTextBlock"
                         Margin="0,12,0,0"
                         Style="{StaticResource SectionSubtitleTextStyle}" />
            </StackPanel>

            <StackPanel x:Name="ServiceStatePanel"
                        Margin="0,16,0,0"
                        Visibility="Collapsed">
              <TextBlock Text="サービス名"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox x:Name="PostCheckServiceNameTextBox"
                       Margin="0,6,0,14" />
              <TextBlock Text="期待状態"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <ComboBox x:Name="PostCheckServiceStateComboBox"
                        Margin="0,6,0,0" />
            </StackPanel>
          </StackPanel>
        </GroupBox>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Style="{StaticResource CardBorderStyle}"
            Margin="0,18,0,0"
            Padding="18">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Content="OK"
                Width="110"
                Margin="0,0,10,0"
                Tag="Primary"
                Click="Ok_Click" />
        <Button Content="キャンセル"
                Width="110"
                Click="Cancel_Click" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

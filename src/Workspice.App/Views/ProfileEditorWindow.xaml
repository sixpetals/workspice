<Window x:Class="Workspice.App.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プロファイル編集"
        Width="1180"
        Height="820"
        MinWidth="1040"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320" />
      <ColumnDefinition Width="20" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Style="{StaticResource HeroCardStyle}"
            Margin="0,0,0,18">
      <StackPanel>
        <TextBlock Text="Workspice Profile Studio"
                   Style="{StaticResource WindowTitleTextStyle}" />
        <TextBlock Text="作業環境ごとの起動アクション、終了アクション、壁紙設定を1つの場所で整えられる編集画面です。"
                   Style="{StaticResource HeroSubtitleTextStyle}"
                   Margin="0,10,0,0" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.ColumnSpan="3"
            Style="{StaticResource CardBorderStyle}"
            Margin="0,0,0,18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="アプリ設定"
                     Style="{StaticResource SectionTitleTextStyle}" />
          <TextBlock Text="常駐動作まわりの基本設定です。プロファイル編集とは独立して保存されます。"
                     Style="{StaticResource SectionSubtitleTextStyle}"
                     Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <CheckBox x:Name="StartWithWindowsCheckBox"
                    Content="Windows ログオン時に自動起動"
                    Margin="0,0,18,0" />
          <TextBlock Text="ログ保持日数"
                     Style="{StaticResource FieldLabelTextStyle}" />
          <TextBox x:Name="LogRetentionDaysTextBox"
                   Width="90"
                   Margin="10,0,0,0" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            Grid.Column="0"
            Style="{StaticResource CardBorderStyle}">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="Profiles"
                     Style="{StaticResource SectionTitleTextStyle}" />
          <TextBlock Text="切り替え対象の作業プロファイルです。左で選んで右側の詳細を編集します。"
                     Style="{StaticResource SectionSubtitleTextStyle}"
                     Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="0,18,0,0">
          <Button Content="追加"
                  Width="82"
                  Margin="0,0,10,0"
                  Tag="Primary"
                  Click="AddProfile_Click" />
          <Button Content="削除"
                  Width="82"
                  Margin="0,0,10,0"
                  Tag="Danger"
                  Click="RemoveProfile_Click" />
          <Button Content="複製"
                  Width="82"
                  Click="CloneProfile_Click" />
        </StackPanel>

        <ListBox x:Name="ProfilesListBox"
                 Margin="0,18,0,0"
                 DisplayMemberPath="Name"
                 SelectionChanged="ProfilesListBox_SelectionChanged" />
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Row="2"
                  Grid.Column="2"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}"
                Margin="0,0,0,18">
          <StackPanel>
            <TextBlock Text="基本情報"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="プロファイル名、説明、壁紙の切り替え方を管理します。"
                       Style="{StaticResource SectionSubtitleTextStyle}"
                       Margin="0,6,0,0" />

            <Grid Margin="0,20,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="名前"
                         Style="{StaticResource FieldLabelTextStyle}" />
              <TextBox Grid.Row="0"
                       Grid.Column="1"
                       x:Name="ProfileNameTextBox"
                       TextChanged="ProfileFields_Changed" />

              <TextBlock Grid.Row="1"
                         Grid.Column="0"
                         Text="説明"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <TextBox Grid.Row="1"
                       Grid.Column="1"
                       x:Name="ProfileDescriptionTextBox"
                       Height="92"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       VerticalContentAlignment="Top"
                       Margin="0,14,0,0"
                       TextChanged="ProfileFields_Changed" />

              <TextBlock Grid.Row="2"
                         Grid.Column="0"
                         Text="壁紙モード"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <ComboBox Grid.Row="2"
                        Grid.Column="1"
                        x:Name="WallpaperModeComboBox"
                        Margin="0,14,0,0"
                        SelectionChanged="ProfileFields_Changed" />

              <TextBlock Grid.Row="3"
                         Grid.Column="0"
                         Text="壁紙パス"
                         Style="{StaticResource FieldLabelTextStyle}"
                         Margin="0,14,0,0" />
              <TextBox Grid.Row="3"
                       Grid.Column="1"
                       x:Name="WallpaperPathTextBox"
                       Margin="0,14,0,0"
                       TextChanged="ProfileFields_Changed" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock Text="アクション構成"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="プロファイル適用時と離脱時の処理を分けて管理します。並び順が実行順になります。"
                       Style="{StaticResource SectionSubtitleTextStyle}"
                       Margin="0,6,0,0" />

            <TabControl Margin="0,20,0,0">
              <TabItem Header="起動時アクション">
                <Grid Margin="0,18,0,0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <ListBox x:Name="LaunchActionsListBox"
                           DisplayMemberPath="Name" />
                  <StackPanel Grid.Row="1"
                              Orientation="Horizontal"
                              Margin="0,16,0,0">
                    <Button Content="追加"
                            Width="82"
                            Margin="0,0,10,0"
                            Tag="Primary"
                            Click="AddLaunchAction_Click" />
                    <Button Content="編集"
                            Width="82"
                            Margin="0,0,10,0"
                            Click="EditLaunchAction_Click" />
                    <Button Content="削除"
                            Width="82"
                            Margin="0,0,10,0"
                            Tag="Danger"
                            Click="RemoveLaunchAction_Click" />
                    <Button Content="上へ"
                            Width="82"
                            Margin="0,0,10,0"
                            Click="MoveLaunchActionUp_Click" />
                    <Button Content="下へ"
                            Width="82"
                            Click="MoveLaunchActionDown_Click" />
                  </StackPanel>
                </Grid>
              </TabItem>

              <TabItem Header="終了時アクション">
                <Grid Margin="0,18,0,0">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <ListBox x:Name="ShutdownActionsListBox"
                           DisplayMemberPath="Name" />
                  <StackPanel Grid.Row="1"
                              Orientation="Horizontal"
                              Margin="0,16,0,0">
                    <Button Content="追加"
                            Width="82"
                            Margin="0,0,10,0"
                            Tag="Primary"
                            Click="AddShutdownAction_Click" />
                    <Button Content="編集"
                            Width="82"
                            Margin="0,0,10,0"
                            Click="EditShutdownAction_Click" />
                    <Button Content="削除"
                            Width="82"
                            Margin="0,0,10,0"
                            Tag="Danger"
                            Click="RemoveShutdownAction_Click" />
                    <Button Content="上へ"
                            Width="82"
                            Margin="0,0,10,0"
                            Click="MoveShutdownActionUp_Click" />
                    <Button Content="下へ"
                            Width="82"
                            Click="MoveShutdownActionDown_Click" />
                  </StackPanel>
                </Grid>
              </TabItem>
            </TabControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="3"
            Grid.ColumnSpan="3"
            Style="{StaticResource CardBorderStyle}"
            Margin="0,18,0,0"
            Padding="18">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Content="保存"
                Width="110"
                Margin="0,0,10,0"
                Tag="Primary"
                Click="Save_Click" />
        <Button Content="キャンセル"
                Width="110"
                Click="Cancel_Click" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

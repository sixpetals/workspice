<Window x:Class="Workspice.App.Views.ProfileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プロファイル編集"
        Width="1100"
        Height="760"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="16" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,12">
      <CheckBox x:Name="StartWithWindowsCheckBox" Content="Windows ログオン時に自動起動" VerticalAlignment="Center" Margin="0,0,16,0" />
      <TextBlock Text="ログ保持日数" VerticalAlignment="Center" />
      <TextBox x:Name="LogRetentionDaysTextBox" Width="80" Margin="8,0,0,0" />
    </StackPanel>

    <DockPanel Grid.Row="1" Grid.Column="0">
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
        <Button Content="追加" Width="72" Margin="0,0,8,0" Click="AddProfile_Click" />
        <Button Content="削除" Width="72" Margin="0,0,8,0" Click="RemoveProfile_Click" />
        <Button Content="複製" Width="72" Click="CloneProfile_Click" />
      </StackPanel>
      <ListBox x:Name="ProfilesListBox" DisplayMemberPath="Name" SelectionChanged="ProfilesListBox_SelectionChanged" />
    </DockPanel>

    <ScrollViewer Grid.Row="1" Grid.Column="2" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="基本情報" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
        <Grid Margin="0,0,0,16">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Row="0" Grid.Column="0" Text="名前" VerticalAlignment="Center" />
          <TextBox Grid.Row="0" Grid.Column="1" x:Name="ProfileNameTextBox" TextChanged="ProfileFields_Changed" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="説明" VerticalAlignment="Center" Margin="0,8,0,0" />
          <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProfileDescriptionTextBox" Height="72" AcceptsReturn="True" Margin="0,8,0,0" TextChanged="ProfileFields_Changed" />
          <TextBlock Grid.Row="2" Grid.Column="0" Text="壁紙モード" VerticalAlignment="Center" Margin="0,8,0,0" />
          <ComboBox Grid.Row="2" Grid.Column="1" x:Name="WallpaperModeComboBox" Margin="0,8,0,0" SelectionChanged="ProfileFields_Changed" />
          <TextBlock Grid.Row="3" Grid.Column="0" Text="壁紙パス" VerticalAlignment="Center" Margin="0,8,0,0" />
          <TextBox Grid.Row="3" Grid.Column="1" x:Name="WallpaperPathTextBox" Margin="0,8,0,0" TextChanged="ProfileFields_Changed" />
        </Grid>

        <TabControl>
          <TabItem Header="起動時アクション">
            <Grid Margin="0,12,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <ListBox x:Name="LaunchActionsListBox" DisplayMemberPath="Name" />
              <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="追加" Width="72" Margin="0,0,8,0" Click="AddLaunchAction_Click" />
                <Button Content="編集" Width="72" Margin="0,0,8,0" Click="EditLaunchAction_Click" />
                <Button Content="削除" Width="72" Margin="0,0,8,0" Click="RemoveLaunchAction_Click" />
                <Button Content="上へ" Width="72" Margin="0,0,8,0" Click="MoveLaunchActionUp_Click" />
                <Button Content="下へ" Width="72" Click="MoveLaunchActionDown_Click" />
              </StackPanel>
            </Grid>
          </TabItem>
          <TabItem Header="終了時アクション">
            <Grid Margin="0,12,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <ListBox x:Name="ShutdownActionsListBox" DisplayMemberPath="Name" />
              <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="追加" Width="72" Margin="0,0,8,0" Click="AddShutdownAction_Click" />
                <Button Content="編集" Width="72" Margin="0,0,8,0" Click="EditShutdownAction_Click" />
                <Button Content="削除" Width="72" Margin="0,0,8,0" Click="RemoveShutdownAction_Click" />
                <Button Content="上へ" Width="72" Margin="0,0,8,0" Click="MoveShutdownActionUp_Click" />
                <Button Content="下へ" Width="72" Click="MoveShutdownActionDown_Click" />
              </StackPanel>
            </Grid>
          </TabItem>
        </TabControl>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="保存" Width="96" Margin="0,0,8,0" Click="Save_Click" />
      <Button Content="キャンセル" Width="96" Click="Cancel_Click" />
    </StackPanel>
  </Grid>
</Window>
